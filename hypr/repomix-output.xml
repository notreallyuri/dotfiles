}

windowrule {
  name = "steam_friend_list_fix"
  match:class = ^(steam)$
  match:title = ^(Friends List)$
  float = 1
  size = 300 600
  center = 1
}

windowrule {
  name        = "steam_settings_fix"
  match:class = ^(steam)$
  match:title = ^(Steam Settings)$
  float       = 1
  size        = 1000 800
